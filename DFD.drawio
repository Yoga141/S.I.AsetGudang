        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;flowchart TD\n    E3((Staff Gudang)); E4((Manager)); E7((Supplier))\n    D2[(D2 Aset)]; D3[(D3 Pengadaan)]; D6[(D6 Log &amp; Notifikasi)]; D7[(D7 File Storage)]\n\n    P4_1[\&quot;4.1 Buat Permintaan\\nAset\&quot;]\n    P4_2[\&quot;4.2 Setujui/Tolak\\nPermintaan Aset\&quot;]\n    P4_3[\&quot;4.3 Evaluasi &amp;\\nSeleksi Vendor\&quot;]\n    P4_4[\&quot;4.4 Buat Purchase\\nOrder\&quot;]\n    P4_5[\&quot;4.5 Unggah Dokumen\\nPurchase Order\&quot;]\n    P4_6[\&quot;4.6 Masukkan Data\\nAnggaran\&quot;]\n    P4_7[\&quot;4.7 Terima Aset &amp;\\nCatat GRN\&quot;]\n    P4_8[\&quot;4.8 Verifikasi Berkas\\nPenerimaan Aset\&quot;]\n    P4_9[\&quot;4.9 Batalkan\\nPengadaan\&quot;]\n    P4_10[\&quot;4.10 Buat Laporan\\nRetur Barang\&quot;]\n    P4_11[\&quot;4.11 Lihat Status &amp;\\nLaporan Pengadaan\&quot;]\n\n    E3 --&gt;|Form permintaan| P4_1 --&gt; D3\n    D3 --&gt; P4_2\n    E4 --&gt;|Keputusan approval| P4_2 --&gt; D3\n    E3 --&gt;|Daftar calon supplier| P4_3 --&gt; D3\n    P4_2 --&gt;|Permintaan disetujui| P4_4 --&gt; D3\n    P4_4 --&gt;|Dokumen PO| E7\n    E3 --&gt;|File PO| P4_5 --&gt; D7\n    E4 --&gt;|Data anggaran| P4_6 --&gt; D3\n    E7 --&gt;|Barang &amp; dokumen kirim| P4_7\n    P4_7 &lt;--&gt;|Data GRN| D3\n    P4_7 --&gt;|Update stok aset baru| D2\n    P4_7 --&gt; P4_8\n    P4_8 &lt;--&gt;|Cek kelengkapan berkas| D3\n    E3 --&gt;|Permintaan batal| P4_9 --&gt; D3\n    P4_8 --&gt;|Barang tidak sesuai| P4_10 --&gt; D3\n    D3 --&gt; P4_11 --&gt;|Status &amp; laporan| E3\n    P4_7 -.-&gt; D6&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="f_D62JlAMrO6e_QJ7AKn-1">

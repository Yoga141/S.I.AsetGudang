  <diagram name="Page-1" id="JWdYljZAyK1FIgwAKHhN">
    <mxGraphModel dx="3031" dy="1620" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1100" pageHeight="850" background="#ffffff" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\n    class User {\n        -String userId\n        -String nama\n        -String email\n        -String username\n        -String passwordHash\n        -String role\n        -String status\n        -Boolean is2FAEnabled\n        -DateTime lastLogin\n        +login(username, password) Boolean\n        +logout() void\n        +changePassword(oldPass, newPass) Boolean\n        +updateProfile(data) Boolean\n        +enable2FA(method) Boolean\n        +resetPasswordViaEmail(email) Boolean\n    }\n\n    class Admin {\n        -String hakAksesLevel\n        +tambahAkunPengguna(data) User\n        +nonaktifkanAkun(userId) Boolean\n        +konfigurasiRBAC(role, akses) Boolean\n        +backupData() Boolean\n        +restoreData(fileBackup) Boolean\n        +konfigurasiNotifikasi(setting) Boolean\n        +updateMasterData(data) Boolean\n        +hapusDataAset(assetId) Boolean\n        +cetakLabelAset(assetId) String\n        +lihatLogAktivitas() List~AuditLog~\n    }\n\n    class StaffGudang {\n        +daftarkanAsetBaru(data) Aset\n        +editDataAset(assetId, data) Boolean\n        +catatMutasiAset(assetId, mutasi) Boolean\n        +unggahFotoAset(assetId, foto) Boolean\n        +tambahKategoriAset(data) Kategori\n        +catatLokasiAset(assetId, lokasi) Boolean\n        +buatPermintaanAset(data) PurchaseOrder\n        +terimaAsetDariSupplier(poId) Boolean\n        +catatGRN(poId, data) Boolean\n    }\n\n    class Manager {\n        +setujuiPermintaanAset(poId) Boolean\n        +tolakPermintaanAset(poId, alasan) Boolean\n        +setujuiJadwalPerawatan(jadwalId) Boolean\n        +monitorKondisiAset() List~Aset~\n        +lihatDashboardRingkasan() Object\n        +lihatLaporanPengadaan() List~PurchaseOrder~\n        +lihatLaporanPemeliharaan() List~TiketPerbaikan~\n        +tutupTiketPerbaikan(tiketId) Boolean\n    }\n\n    class Teknisi {\n        +buatJadwalPerawatan(assetId, data) Boolean\n        +catatHasilInspeksi(assetId, hasil) Boolean\n        +perbaruiStatusPerbaikan(tiketId, status) Boolean\n        +unggahBuktiPerbaikan(tiketId, file) Boolean\n        +catatBiayaPemeliharaan(tiketId, biaya) Boolean\n        +perbaruiPrioritasTiket(tiketId, prioritas) Boolean\n    }\n\n    class Auditor {\n        +catatHasilAudit(assetId, hasil) AuditLog\n        +verifikasiKesesuaianDataAset(assetId) Boolean\n        +tandaiAsetSelisih(assetId, keterangan) Boolean\n        +buatBeritaAcaraAudit(data) String\n        +cetakLaporanAudit() String\n    }\n\n    class Aset {\n        -String assetId\n        -String namaAset\n        -String kodeAset\n        -String kategoriId\n        -String lokasiId\n        -Date tanggalPerolehan\n        -Double nilaiPerolehan\n        -String kondisi\n        -String status\n        -String deskripsi\n        -String fotoUrl\n        -String qrCode\n        +getDetail() Object\n        +getRiwayat() List~Object~\n        +updateStatus(status) Boolean\n        +hitungPenyusutan() Double\n    }\n\n    class Kategori {\n        -String kategoriId\n        -String namaKategori\n        -String kodeKategori\n        -String deskripsi\n        -String metodePenyusutan\n        +tambah(data) Boolean\n        +update(data) Boolean\n    }\n\n    class Lokasi {\n        -String lokasiId\n        -String gedung\n        -String ruangan\n        -String lantai\n        -String keterangan\n        +update(data) Boolean\n        +getHistoriPerpindahan() List~Object~\n    }\n\n    class TiketPerbaikan {\n        -String tiketId\n        -String assetId\n        -String deskripsiKerusakan\n        -String prioritas\n        -String status\n        -Date tanggalDibuat\n        -Date tanggalSelesai\n        -Double biayaPemeliharaan\n        -String buktiPerbaikanUrl\n        +buatTiket(data) Boolean\n        +updateStatus(status) Boolean\n        +tutupTiket() Boolean\n    }\n\n    class PurchaseOrder {\n        -String poId\n        -String requestId\n        -String assetId\n        -String supplier\n        -Date tanggalPO\n        -Double totalNilai\n        -String status\n        -String dokumenPOUrl\n        +buatPO(data) Boolean\n        +setujui() Boolean\n        +tolak(alasan) Boolean\n        +catatGRN(data) Boolean\n        +buatLaporanRetur(data) Boolean\n    }\n\n    class AuditLog {\n        -String logId\n        -String userId\n        -String aksi\n        -DateTime timestamp\n        -String ipAddress\n        -String deskripsi\n        +catatLog(aksi, userId) Boolean\n        +exportLog(filter) String\n        +filterLog(kriteria) List~AuditLog~\n    }\n\n    User &lt;|-- Admin\n    User &lt;|-- StaffGudang\n    User &lt;|-- Manager\n    User &lt;|-- Teknisi\n    User &lt;|-- Auditor\n\n    Aset \&quot;many\&quot; --&gt; \&quot;1\&quot; Kategori : include\n    Aset \&quot;many\&quot; --&gt; \&quot;1\&quot; Lokasi : include\n    Aset \&quot;1\&quot; --&gt; \&quot;many\&quot; TiketPerbaikan : extend\n    Aset \&quot;1\&quot; --&gt; \&quot;many\&quot; PurchaseOrder : extend\n    Aset \&quot;1\&quot; --&gt; \&quot;many\&quot; AuditLog : extend\n\n    StaffGudang \&quot;1\&quot; --&gt; \&quot;many\&quot; Aset : include\n    StaffGudang \&quot;1\&quot; --&gt; \&quot;many\&quot; PurchaseOrder : extend\n    Teknisi \&quot;1\&quot; --&gt; \&quot;many\&quot; TiketPerbaikan : include\n    Manager \&quot;1\&quot; --&gt; \&quot;many\&quot; PurchaseOrder : include\n    Auditor \&quot;1\&quot; --&gt; \&quot;many\&quot; AuditLog : include\n    User \&quot;1\&quot; --&gt; \&quot;many\&quot; AuditLog : extend\n&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="muw0WhFnR1SbuX7ksu-M-1">
